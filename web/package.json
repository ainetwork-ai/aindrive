    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@tanstack/react-query": "^5.100.1",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-collaboration": "^3.26.0",
    "@tiptap/extension-collaboration-caret": "^3.26.0",
    "@tiptap/markdown": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@x402/core": "~2.14.0",
    "@x402/evm": "~2.14.0",
    "@x402/fetch": "~2.14.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.7.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^5.9.6",
    "lucide-react": "^0.468.0",
    "mime-types": "^2.1.35",
    "nanoid": "^5.0.9",
    "next": "^15.1.3",
    "nodemailer": "^9.0.3",
    "pino": "^10.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "siwe": "^3.0.0",
    "sonner": "^2.0.7",
    "use-debounce": "^10.1.1",
