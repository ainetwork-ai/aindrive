{
  "name": "aindrive-web",
  "version": "0.1.0",
  "private": true,
  "description": "aindrive web — Next.js UI + WS server that brokers between browsers and locally-running aindrive CLI agents.",
  "type": "module",
  "scripts": {
    "copy-monaco": "node scripts/copy-monaco.mjs",
    "predev": "node scripts/copy-monaco.mjs",
    "prebuild": "node scripts/copy-monaco.mjs",
    "dev": "node server.js",
    "build": "next build",
    "start": "NODE_ENV=production node server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run lib/",
    "test:watch": "vitest lib/",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:ui": "vitest --ui scenarios/"
  },
