    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
