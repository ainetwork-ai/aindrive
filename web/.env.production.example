# ─────────────────────────────────────────────────────────────────────────
# PRODUCTION (Base mainnet) env template — copy to `.env.production`, fill in,
# and on the deploy host expose it to Docker as `.env` (compose reads
# `env_file: ./.env`). NEVER commit the filled file — only this *.example is
# tracked; real .env* is gitignored.
#
# Local dev uses `.env.local` (DEV_BYPASS, testnet). This file is the
# real-money path: every value here moves real funds or gates them.
# ─────────────────────────────────────────────────────────────────────────

# Data directory for SQLite + Yjs docs (Docker volume mount).
AINDRIVE_DATA_DIR=/data

# Session JWT secret — REQUIRED in prod (no file fallback). 32+ random bytes:
#   openssl rand -hex 32
AINDRIVE_SESSION_SECRET=replace-me

# Public https URL (cookies/share links bind to it). Must be https in prod.
AINDRIVE_PUBLIC_URL=https://aindrive.ainetwork.ai

# ── Payment network ───────────────────────────────────────────────────────
# `mainnet` flips chain + USDC preset + wallet default as one set. It is
# NEXT_PUBLIC (inlined into the browser bundle at BUILD time), so changing it
# REQUIRES `docker compose build` — a runtime restart alone leaves the client
# bundle on testnet (split-brain). compose passes this as a build arg.
NEXT_PUBLIC_AINDRIVE_PAYMENT_NETWORK=mainnet

# ── Facilitator (who settles payments on-chain) ───────────────────────────
# Mainnet has NO safe default — without a configured facilitator the server
# refuses payments with 503 (intentional, prevents misrouted funds).
# Use Coinbase CDP for mainnet (keys: https://portal.cdp.coinbase.com →
# API keys → Secret API keys → Create). Settle path needs the secret key.
CDP_API_KEY_ID=replace-me
CDP_API_KEY_SECRET=replace-me
# Leave AINDRIVE_X402_FACILITATOR UNSET on mainnet: an explicit URL takes
# precedence over the CDP keys, so setting it (e.g. to x402.org) would make
# CDP be ignored and mainnet settles fail. Only set it for a self-hosted /
# third-party facilitator you control.
#AINDRIVE_X402_FACILITATOR=

# Owner payout wallet — where buyers' funds land. Verify this is YOUR address.
AINDRIVE_PAYOUT_WALLET=0xReplaceWithRealPayoutWallet

# ── Safety rails ──────────────────────────────────────────────────────────
# MUST be 0 (or unset) in prod. =1 skips on-chain verification entirely —
# dev/demo only. Never on mainnet.
AINDRIVE_DEV_BYPASS_X402=0

# WalletConnect Cloud project id (https://cloud.walletconnect.com) for
# WalletConnect wallets; injected wallets (MetaMask/Coinbase) work without it.
NEXT_PUBLIC_WC_PROJECT_ID=

# ── Go-live checklist (do these IN ORDER) ─────────────────────────────────
#  1. Revoke any CDP key that was ever pasted into chat/logs; issue a fresh one.
#  2. Fill the values above in `.env.production` (gitignored).
#  3. Expose it to compose as `.env` on the deploy host.
#  4. `docker compose build` (NEXT_PUBLIC_* is build-time — restart is NOT enough).
#  5. Confirm: DEV_BYPASS=0, payout wallet correct, AINDRIVE_X402_FACILITATOR unset.
#  6. Smoke-test with a SMALL real USDC purchase (testnet cannot substitute).
#  7. For custom permit2 tokens (e.g. FANCO), confirm CDP /supported lists them
#     on mainnet before relying on settlement.
