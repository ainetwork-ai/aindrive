# Data directory for SQLite + Yjs docs (mounted as a volume in Docker).
AINDRIVE_DATA_DIR=/data

# Session JWT secret (32+ random bytes, e.g. openssl rand -hex 32)
AINDRIVE_SESSION_SECRET=replace-me

# Public URL — your custom domain.
AINDRIVE_PUBLIC_URL=https://aindrive.ainetwork.ai

# x402 paywall — owner payout wallet (where buyers' USDC is sent)
AINDRIVE_PAYOUT_WALLET=0x0000000000000000000000000000000000000000

# x402 facilitator, picked in this order:
#   1. AINDRIVE_X402_FACILITATOR — explicit URL (self-hosted / third party)
#   2. CDP_API_KEY_ID + CDP_API_KEY_SECRET — Coinbase CDP facilitator
#      (required for Base MAINNET settles incl. permit2; keys from
#      https://portal.cdp.coinbase.com)
#   3. neither — free public x402.org, TESTNET ONLY (mainnet refuses with 503)
AINDRIVE_X402_FACILITATOR=https://x402.org/facilitator
#CDP_API_KEY_ID=
#CDP_API_KEY_SECRET=

# Skip on-chain verification for local demos (1=on, 0=off). Use only in dev.
AINDRIVE_DEV_BYPASS_X402=0

# WalletConnect Cloud project ID (free at https://cloud.walletconnect.com).
# Required for WalletConnect-based wallets; injected wallets (MetaMask) work without it.
NEXT_PUBLIC_WC_PROJECT_ID=
