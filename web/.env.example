# aindrive env template. Only *.example is committed; real .env* is gitignored.
#
# ONE file per environment — copy this to:
#   .env.production — the Docker deploy file. Holds EVERYTHING for prod: the
#                     runtime secrets (CDP keys, SESSION_SECRET, …) AND the
#                     NEXT_PUBLIC_* build vars. Build/run with the flag that
#                     points Compose at it (its ${...} interpolation defaults
#                     to `.env`, so the name must be passed explicitly):
#                       docker compose --env-file .env.production up -d --build
#   .env.local      — local dev only (running `node server.js` directly):
#                     testnet + DEV_BYPASS, no CDP keys. Loaded by @next/env.
#
# Everything below is what an OPERATOR sets. Code-internal/tuning vars
# (RPC URLs, size limits, log level, trace, SQLite) all have sane defaults
# and are NOT listed here — set them only if you need to override
# (see process.env.AINDRIVE_* in the code).

# ── Core ──────────────────────────────────────────────────────────────────
# NOTE: AINDRIVE_DATA_DIR (SQLite + Yjs storage) is NOT set here — each run
# context provides it: Docker compose sets /data + a volume, the e2e harness a
# temp dir, and the code defaults to ~/.aindrive. Set it only in .env.local for
# local dev (an isolated dir, separate from prod data / the CLI's creds).

# Session JWT secret. REQUIRED in prod.  openssl rand -hex 32
AINDRIVE_SESSION_SECRET=replace-me
# Public origin (cookies + share links bind to it). Must be https:// in prod.
AINDRIVE_PUBLIC_URL=http://localhost:3737

# ── Payments (x402) ─────────────────────────────────────────────────────────
# testnet (base-sepolia, default) or mainnet (base). NEXT_PUBLIC = inlined at
# BUILD time, so changing it needs `docker compose build`, not just a restart.
NEXT_PUBLIC_AINDRIVE_PAYMENT_NETWORK=testnet
# Skip on-chain verification for local demos (1=on). MUST be 0/unset in prod.
AINDRIVE_DEV_BYPASS_X402=0
# Facilitator that settles payments:
#   testnet → leave both unset, free public x402.org is the default.
#   mainnet → set CDP keys (https://portal.cdp.coinbase.com → API keys →
#             Secret API keys). Required; without them mainnet refuses with 503.
#CDP_API_KEY_ID=
#CDP_API_KEY_SECRET=
# Override facilitator URL only for a self-hosted/third-party one. If set, it
# takes precedence over the CDP keys — leave UNSET on mainnet when using CDP.
#AINDRIVE_X402_FACILITATOR=
#
# NOTE: there is no global payout wallet. Each drive's owner sets its own
# payout wallet in Settings → Payments; selling is blocked until they do.

# ── Optional ────────────────────────────────────────────────────────────────
# WalletConnect Cloud project id (https://cloud.walletconnect.com). Only needed
# for WalletConnect wallets; injected wallets (MetaMask/Coinbase) work without.
NEXT_PUBLIC_WC_PROJECT_ID=
