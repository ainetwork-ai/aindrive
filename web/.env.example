# Postgres (Neon via Vercel Marketplace — auto-injected on deploy)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Session JWT secret (32+ random bytes, e.g. openssl rand -hex 32)
AINDRIVE_SESSION_SECRET=replace-me

# Public URL (Vercel auto-sets VERCEL_URL; override for custom domain)
AINDRIVE_PUBLIC_URL=https://aindrive.vercel.app
